APP_NAME=ICS Detection API
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
DATABASE_URL=postgresql+psycopg2://ics_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/icssec
REDIS_URL=redis://redis:6379/0
ML_SERVICE_URL=http://ml-service:8001
# Must match ml-service ML_INTERNAL_API_KEY when set
ML_SERVICE_API_KEY=
ML_INFER_TIMEOUT_SECONDS=60
ML_RETRAIN_TIMEOUT_SECONDS=120
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_NAME=ics_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_PATH=/
CSRF_PROTECTION_ENABLED=true
CSRF_COOKIE_NAME=ics_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_EXPIRE_HOURS=12
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
EMAIL_VERIFICATION_REQUIRED=false
EXPOSE_AUTH_TOKENS=false
# Disabled by default — never enable in production (docker-compose.prod.yml forces false).
# Local only: run scripts/dev-local-admin.ps1 to generate a random password; disable after first admin exists.
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
HIDDEN_ADMIN_EMAILS=
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ICS Guard
FRONTEND_BASE_URL=http://localhost:8080
EMAIL_VERIFICATION_PATH=/verify-email
PASSWORD_RESET_PATH=/reset-password
RATE_LIMIT_PER_MINUTE=120
METRICS_PUBLIC=false
PUBLIC_LIVE_SNAPSHOT_ENABLED=false
CSP_REPORT_MAX_BYTES=8192
SSE_INTERVAL_SECONDS=5
SSE_MAX_CONNECTIONS=50
SSE_MAX_CONNECTION_SECONDS=1800
PACKET_CAPTURE_DIR=./captures
DEVICE_OFFLINE_AFTER_MINUTES=60
