APP_NAME=ICS Detection API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
DATABASE_URL=postgresql+psycopg2://ics_user:ics_password@postgres:5432/icssec
REDIS_URL=redis://redis:6379/0
ML_SERVICE_URL=http://ml-service:8001
JWT_SECRET_KEY=change-me-super-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
EMAIL_VERIFICATION_REQUIRED=false
EXPOSE_AUTH_TOKENS=false
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@ics.local
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_NAME=Admin
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ICS Guard
FRONTEND_BASE_URL=
EMAIL_VERIFICATION_PATH=/verify-email
PASSWORD_RESET_PATH=/reset-password
RATE_LIMIT_PER_MINUTE=120
PACKET_CAPTURE_DIR=./captures
