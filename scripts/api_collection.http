### Login
POST http://localhost:8080/api/v1/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

### Upload Traffic
POST http://localhost:8080/api/v1/traffic/ingest
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "source_ip": "10.0.0.11",
  "destination_ip": "10.0.0.55",
  "source_port": 50222,
  "destination_port": 502,
  "transport_protocol": "tcp",
  "packet_count": 75,
  "bytes_in": 3500,
  "bytes_out": 2800,
  "duration_ms": 155,
  "payload_entropy": 5.1,
  "modbus_function_code": 16,
  "modbus_unit_id": 4,
  "dnp3_function_code": 1,
  "iec104_type_id": 45,
  "ingestion_source": "json",
  "metadata_json": {"site": "west"}
}

### Run Detection
POST http://localhost:8080/api/v1/traffic/{{record_id}}/detect
Authorization: Bearer {{token}}

### List Alerts
GET http://localhost:8080/api/v1/alerts
Authorization: Bearer {{token}}

### Retrain Model
POST http://localhost:8080/api/v1/model/retrain
Authorization: Bearer {{token}}

### Register
POST http://localhost:8080/api/v1/auth/register
Content-Type: application/json

{
  "full_name": "Test User",
  "email": "testuser@example.com",
  "password": "Password123!"
}

### Forgot Password
POST http://localhost:8080/api/v1/auth/forgot-password
Content-Type: application/json

{
  "email": "testuser@example.com"
}

### Reset Password
POST http://localhost:8080/api/v1/auth/reset-password
Content-Type: application/json

{
  "token": "REPLACE_WITH_RESET_TOKEN",
  "new_password": "NewPassword123!"
}

### Request Email Verification
POST http://localhost:8080/api/v1/auth/request-email-verification
Authorization: Bearer {{token}}

### Verify Email
POST http://localhost:8080/api/v1/auth/verify-email
Content-Type: application/json

{
  "token": "REPLACE_WITH_VERIFY_TOKEN"
}

### List Roles
GET http://localhost:8080/api/v1/rbac/roles
Authorization: Bearer {{token}}

### Create Role
POST http://localhost:8080/api/v1/rbac/roles
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "operator",
  "description": "General operator role",
  "permission_ids": []
}

### List Permissions
GET http://localhost:8080/api/v1/rbac/permissions
Authorization: Bearer {{token}}

### Create Device
POST http://localhost:8080/api/v1/devices
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "PLC-1",
  "device_type": "PLC",
  "ip_address": "192.168.1.50",
  "serial_number": "SN-98765",
  "location": "Control Room A"
}

### List Devices
GET http://localhost:8080/api/v1/devices
Authorization: Bearer {{token}}

### Trigger Packet Capture
POST http://localhost:8080/api/v1/packet-capture
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "interface": "eth0",
  "duration_seconds": 10,
  "output_filename": "manual_capture.pcap"
}
