# Compose-level shared settings (copy to .env — never commit real secrets)
POSTGRES_DB=icssec
POSTGRES_USER=ics_user
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
APP_ENV=development
APP_DEBUG=false
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_NAME=ics_access_token
# true when serving over HTTPS (production/staging)
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
ML_INFER_TIMEOUT_SECONDS=60
ML_RETRAIN_TIMEOUT_SECONDS=120
SSE_MAX_CONNECTIONS=50
SSE_MAX_CONNECTION_SECONDS=1800
# Shared secret between backend and ml-service (generate: openssl rand -hex 24)
ML_SERVICE_API_KEY=REPLACE_WITH_ML_INTERNAL_KEY
BACKEND_PORT=8000
ML_PORT=8001
FRONTEND_PORT=5173
GATEWAY_PORT=8080
GATEWAY_HTTPS_PORT=443
TLS_CERT_PATH=./gateway/certs/fullchain.pem
TLS_KEY_PATH=./gateway/certs/privkey.pem
